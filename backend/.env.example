# Backend Environment Variables
# Copy this to .env and fill with your actual values
# NEVER commit .env to git

# Server Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=odiecloud_db
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_SSL=false

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CSRF_SECRET=your_csrf_secret_key_here

# CORS Configuration
CORS_ORIGIN=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Email Configuration (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
EMAIL_FROM=noreply@odiecloud.com
EMAIL_FROM_NAME=ODIECLOUD²π

# Admin Configuration
ADMIN_EMAIL=admin@odiecloud.com
ADMIN_PASSWORD=change_this_secure_password

# File Upload (if needed later)
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Session (if using sessions instead of JWT)
SESSION_SECRET=your_session_secret_key_here
SESSION_EXPIRE=86400000

# Feature Flags
ENABLE_EMAIL_VERIFICATION=true
ENABLE_RATE_LIMITING=true
ENABLE_CSRF_PROTECTION=true

# External APIs (for future integrations)
# STRIPE_SECRET_KEY=sk_test_...
# SENDGRID_API_KEY=SG...
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
